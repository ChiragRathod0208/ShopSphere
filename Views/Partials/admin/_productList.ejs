<div class="bg-white shadow ml-4">
    <div class="pt-4 mt-4 border-t-2 border-blue-200"></div>
    <h2 class="px-2 py-2 text-xl font-bold">Product List</h2>
    <div class="pt-4 mt-4 border-t-2 border-blue-200"></div>
    <div class="relative overflow-x-auto bg-neutral-primary-soft shadow-xs rounded-base border border-default">
        <table class="w-full text-sm text-left rt1:text-right text-body">
            <thead class="bg-neutral-secondary-soft border-b border-default">
                <tr>
                    <th scope="col" class="px-6 py-3 font-medium">Sr No.</th>
                    <th scope="col" class="px-6 py-3 font-medium">Name</th>
                    <th scope="col" class="px-6 py-3 font-medium">IMAGE</th>
                    <th scope="col" class="px-6 py-3 font-medium">Price</th>
                    <th scope="col" class="px-6 py-3 font-medium">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% products.forEach((product, idx) => { %>
                    <tr class="odd:bg-neutral-primary even:bg-neutral-secondary-soft border-b border-default text-base">
                        <td class="px-6 py-4"><%= idx + 1 %></td>
                        <td class="px-6 py-4"><%= product.name %></td>
                        <td class="px-6 py-4"><%= product.image %></td>
                        <td class="px-6 py-4"><%= product.price %></td>
                        <td class="px-6 py-4">
                            <!-- <form id="editForm" method="post">
                                <input type="text" id="id" name="id" value=<%=// product._id %> hidden>
                                <button type="submit" class="bg-yellow-400 rounded-md my-2 px-3 py-3"><i class="fa-solid fa-pen-to-square"></i></button>
                            </form> -->
                            <button class="bg-yellow-400 rounded-md my-2 px-3 py-3"><i class="fa-solid fa-pen-to-square" onclick="editProduct('<%= product._id %>')"></i></button>
                            <button class="bg-red-600 rounded-md my-2 px-3 py-3" onclick="deleteProduct('<%= product._id %>')"><i class="fa-solid fa-trash"></i></button>
                        </td>
                    </tr>
                <% }) %>
        </table>

    </div>
</div>

