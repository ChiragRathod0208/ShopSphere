<% cart.Items.forEach((Item, idx) => { %>
    <div class="w-full flex flex-col md:flex-row items-start px-4 py-6 md:px-10 md:py-10 gap-6 md:gap-10 border-b border-gray-100">
        
        <div class="w-full md:w-[35%] lg:w-[30%] rounded-md overflow-hidden bg-gray-50 pb-4">
            <div class="w-full aspect-square md:h-64 lg:h-72">
                <img src="<%= Item.product.image %>"
                    class="h-full w-full object-cover object-center"
                    alt="<%= Item.product.name %>">
            </div>
            
            <div class="w-full flex justify-between items-center px-4 py-4">
                <h3 class="text-xl md:text-2xl font-semibold"><%= Item.product.name %></h3>
                <div class="flex items-center gap-2">
                    <div class="px-3 py-1 rounded-md bg-white border text-black font-medium">
                        Qty: <%= Item.quantity %>
                    </div>
                </div>
            </div>
            
            <div class="flex items-center justify-between px-4">
                <h4 class="text-gray-500">Subtotal</h4>
                <h2 class="text-lg font-bold">₹ <%= (Item.product.price) * Item.quantity %></h2>
            </div>
        </div>

        <div class="w-full md:w-[65%] lg:w-[70%]">
            <h3 class="text-xl font-bold border-b pb-2">Price Breakdown</h3>
            
            <div class="mt-5 space-y-3">
                <div class="flex justify-between md:justify-start">
                    <h4 class="w-1/2 md:w-1/3 text-gray-600">Total MRP</h4>
                    <h4 class="font-medium">₹ <%= Item.product.price %></h4>
                </div>
                <div class="flex justify-between md:justify-start">
                    <h4 class="w-1/2 md:w-1/3 text-gray-600">Discount on MRP</h4>
                    <h4 class="text-green-600">₹ 0</h4>
                </div>
                <div class="flex justify-between md:justify-start">
                    <h4 class="w-1/2 md:w-1/3 text-gray-600">Platform Fee</h4>
                    <h4>₹ 0</h4>
                </div>
                <div class="flex justify-between md:justify-start">
                    <h4 class="w-1/2 md:w-1/3 text-gray-600">Shipping Fee</h4>
                    <h4 class="text-green-600 font-medium">FREE</h4>
                </div>
            </div>

            <div class="w-full h-[1px] bg-gray-200 mt-8"></div>
            
            <div class="flex mt-5">
                <h3 class="w-1/2 md:w-1/3 text-xl font-bold">Total Amount</h3>
                <h3 class="font-bold text-2xl text-green-600">₹ <%= (Item.product.price) * Item.quantity %></h3>
            </div>

            <div class="mt-6 flex gap-4">
                <button onclick="updateQty('<%= Item.product._id %>', 'inc')" 
                        class="flex-1 md:flex-none md:w-16 h-12 flex items-center justify-center rounded-lg bg-blue-600 text-white hover:bg-blue-700 transition">
                    <i class="fa-solid fa-plus text-xl"></i>
                </button>
                
                <button onclick="updateQty('<%= Item.product._id %>', 'dec')" 
                        class="flex-1 md:flex-none md:w-16 h-12 flex items-center justify-center rounded-lg bg-gray-200 text-gray-800 hover:bg-gray-300 transition">
                    <i class="fa-solid fa-minus text-xl"></i>
                </button>
            </div>
        </div>
    </div>
<% }) %>

<div class="flex w-full justify-center p-6 md:p-10">
    <form class="w-full max-w-2xl flex justify-center" onsubmit="orderSubmit(event)">
        <button type="submit" class="text-xl w-full md:w-[60%] flex items-center justify-center gap-3 rounded-xl bg-green-600 text-white py-4 font-bold hover:bg-green-700 transition shadow-lg">
            <i class="fa-solid fa-bag-shopping"></i>
            Order Now
        </button>
    </form>
</div>